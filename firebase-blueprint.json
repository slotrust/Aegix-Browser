{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings for synchronization",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "vpnEnabled": { "type": "boolean" },
            "vpnLocation": { "type": "string" },
            "theme": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt", "updatedAt"]
    },
    "Bookmark": {
      "title": "Bookmark",
      "description": "A saved URL bookmark",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "icon": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url", "createdAt", "updatedAt"]
    },
    "HistoryEntry": {
      "title": "History Entry",
      "description": "A visited page saved in history",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "visitedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url", "visitedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User document storing global settings and act as root for user data."
    },
    "/users/{userId}/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User's synchronized bookmarks."
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "HistoryEntry",
      "description": "User's browsing history."
    }
  }
}
